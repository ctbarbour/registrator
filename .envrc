use flake

# --- Sops-encrypted secrets ---

decrypt_gar_key() {
    local src="$PWD/secrets/gar-key.sops.json"
    local dst="$HOME/.cache/registrator/gar-key.json"
    if [ -e "$src" ] && command -v sops >/dev/null 2>&1; then
        if [ ! -e "$dst" ] || [ "$src" -nt "$dst" ]; then
            mkdir -p "$(dirname "$dst")"
            if sops -d "$src" > "$dst" 2>/dev/null; then
                chmod 600 "$dst"
                log_status "Decrypted GAR service account key to $dst"
            else
                rm -f "$dst"
                log_error "Failed to decrypt GAR key -- check sops age key at ~/.config/sops/age/keys.txt"
            fi
        fi
        if [ -e "$dst" ]; then
            export GOOGLE_APPLICATION_CREDENTIALS="$dst"
            export GAR_KEY_FILE="$dst"
        fi
    fi
    watch_file "$src"
}

if [ -f "$HOME/.config/sops/age/keys.txt" ]; then
    decrypt_gar_key
else
    log_status "sops age key not found -- GAR push will not work without credentials"
fi
