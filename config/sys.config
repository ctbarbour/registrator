[
  {kernel, [
    {logger_level, info}
  ]},
  {registrator, [
    {authoritative_zone, "service.local"},
    %% [{Host, Port}]; appended to by REGISTRATOR_RECURSORS env var. Empty -> REFUSED out-of-zone.
    {recursors, []},
    {advertise, "127.0.0.1"},
    {refresh_ttl, 30000},
    {docker_socket, "/var/run/docker.sock"},
    %% Periodic anti-entropy interval. Each tick picks one random swim peer
    %% and pulls a full ORSet snapshot via TCP, then merges via
    %% riak_dt_orswot:merge/2. Op-gossip handles live updates; this is the
    %% safety net for missed envelopes.
    {sync_interval_ms, 300000},
    {groups, [
      {lan, #{
        %% advertise_ip is the address this node tells peers about. `auto`
        %% picks the first routable IPv4. Override with an explicit tuple
        %% (e.g. {10,0,0,5}) when the autodetected interface is wrong.
        advertise_ip => auto,
        port         => 5000,
        %% TCP port for the anti-entropy state sync server. Peers dial this
        %% to pull the full ORSet. Defaults to swim port + 1000.
        state_sync_port => 6000,
        %% Initial peers to swim:join and pull state from on startup. Each
        %% entry is {Ip, SwimPort}; the state-sync port is derived as
        %% SwimPort + 1000. Leave empty on the first cluster node.
        seeds        => [],
        %% swim base64-decodes this to the raw AES-256 key. Generate a real one with:
        %%   erl -noshell -eval 'io:format("~s~n", [base64:encode(crypto:strong_rand_bytes(32))]), halt().'
        key          => <<"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=">>
      }}
    ]}
  ]}
].
